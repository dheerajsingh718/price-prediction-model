# # Ignore everything by default
# *

# Allow directories
!*/

# Allow specific folders
!notebooks/
!src/

# Allow specific notebooks
!notebooks/01_data_ingestion.ipynb
!notebooks/02_eda.ipynb
!notebooks/03_model_training.ipynb

# Allow specific source files
!src/fix_normalize_function.py
!src/fix_validate_function.py

# Allow root markdown files
!.gitignore
!DATA_AGGREGATION_ROADMAP.md
!IMPROVEMENTS_SUMMARY.md

# Explicitly ignore common junk
.ipynb_checkpoints/
datasets/
logs/
*.xlsx
*.csv
*.parquet

!merged.xlsx
!datasets/
datasets/*
!datasets/eda_cleaned.csv
